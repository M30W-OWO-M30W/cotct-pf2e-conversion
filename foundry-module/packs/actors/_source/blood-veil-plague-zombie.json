      "sort": 700000,
      "system": {
        "description": {
          "value": "<p>An infected creature can't heal damage it takes from zombie rot until it has been cured of the disease.</p>\n<hr />\n<p><strong>Saving Throw</strong> @Check[type:fortitude|dc:18]</p>\n<p><strong>Stage 1</strong> carrier with no ill effect (1 day)</p>\n<p><strong>Stage 2</strong> [[/r {1d6}[negative]]]{1d6 negative damage} (1 day)</p>\n<p><strong>Stage 3</strong> [[/r {1d6}[negative]]]{1d6 negative damage} (1 day)</p>\n<p><strong>Stage 4</strong> [[/r {1d6}[negative]]]{1d6 negative damage} (1 day)</p>\n<p><strong>Stage 5</strong> dead, rising as a plague zombie immediately</p>"
        },
