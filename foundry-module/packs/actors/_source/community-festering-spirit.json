    {
      "type": "action",
      "img": "systems/pf2e/icons/actions/Passive.webp",
      "name": "Slime",
      "system": {
        "description": {
          "value": "<p>Any creature that is hit by the festering spirit's ghostly hand Strike, passes through its square, or hits it with a natural weapon or unarmed strike must attempt a @Check[type:fortitude|dc:27] save. A creature affected by Slime can spend 1 action to Interact and scrape the slime off to reduce the sickened condition by 1.</p>\n<hr>\n<p><strong>Critical Success</strong> The creature is immune to the effects of Slime for 24 hours.</p>\n<p><strong>Success</strong> The creature becomes @Compendium[pf2e.conditionitems.Sickened]{Sickened 1}.</p>\n<p><strong>Failure</strong> The creature becomes @Compendium[pf2e.conditionitems.Sickened]{Sickened 1} and @Compendium[pf2e.conditionitems.Slowed]{Slowed 1}. If the creature loses the sickened condition, they also lose the slowed condition.</p>\n<p><strong>Critical Failure</strong> As failure, but @Compendium[pf2e.conditionitems.Sickened]{Sickened 2}.</p>"
        },
