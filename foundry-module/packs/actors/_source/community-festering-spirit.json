    {
      "type": "action",
      "img": "systems/pf2e/icons/actions/TwoActions.webp",
      "name": "Frightful Moan",
      "system": {
        "description": {
          "value": "<p>The festering spirit laments its fate, forcing each living creature within 30 feet to attempt a @Check[type:will|dc:27] save. On a failure, a creature becomes @Compendium[pf2e.conditionitems.Frightened]{Frightened 2} (or @Compendium[pf2e.conditionitems.Frightened]{Frightened 3} on a critical failure). On a success, a creature is temporarily immune to this festering spirit's frightful moan for 1 minute.</p>"
        },
        "source": {
