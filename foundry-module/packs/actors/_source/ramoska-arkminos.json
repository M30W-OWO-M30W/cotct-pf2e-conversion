    "details": {
      "blurb": "Ancient nosferatu disease-scholar (negotiable)",
      "languages": {
        "details": "",
        "value": [
          "common",
          "necril",
          "varisian",
          "draconic"
        ]
      },
      "level": {
        "value": 13
      },
      "privateNotes": "",
      "publicNotes": "<p><strong>Role:</strong> an ancient <strong>nosferatu</strong> scholar of disease — the deadliest foe in the chapter, and the one the PCs should almost never fight. Lent to the cult by his master Count Tiriac, he loathes his undeath and only wants to find a cure so he can finally die <em>as a man</em>. He has no love for the cult, the queen, or the Red Mantis.</p><p><strong>Negotiation, not battle:</strong> he holds the captive Varisian <strong>Ruan Mirukova</strong> (testing Varisian plague-immunity) and will simply <em>sell</em> him and leave — ~200 gp re-scaled, a magic item, a future favor, or the last <em>death's head coffer</em> from Andaisin's sanctum. If attacked he fights ferociously but flees via Dimensional Step rather than be destroyed. <strong>This is a CR-14-equivalent encounter far above the party — telegraph the danger.</strong></p>",
      "publication": {
        "title": "Pathfinder: Curse of the Crimson Throne (PF2e conversion, private)",
        "authors": "",
        "license": "OGL",
        "remaster": true
      }
