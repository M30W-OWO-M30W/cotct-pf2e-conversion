    {
      "_id": "3F9wdRX9orioME1X",
      "img": "systems/pf2e/icons/actions/OneAction.webp",
      "name": "Prayer Attack",
      "sort": 0,
      "type": "action",
      "system": {
        "actionType": {
          "value": "action"
        },
        "actions": {
          "value": 1
        },
        "category": "offensive",
        "description": {
          "value": "<p>The assassin weaves her blades point-down before a creature within 30 feet that can see her: @Check[type:will|dc:28] or the target is @UUID[Compendium.pf2e.conditionitems.Item.AdPVz7rbaVSRxHFg]{Fascinated} (it may re-save whenever a new threat appears). The assassin Sustains this hypnosis; after sustaining 3 full rounds, her next Saber Strike against the still-fascinated target is an <strong>automatic critical hit</strong> on a success — the Red Mantis's signature execution.</p>"
        },
        "publication": {
          "title": "Pathfinder: Curse of the Crimson Throne (PF2e conversion, private)",
          "authors": "",
          "license": "OGL",
          "remaster": true
        },
        "rules": [],
        "slug": null,
        "traits": {
          "rarity": "common",
          "value": [
            "concentrate",
            "incapacitation",
            "mental",
            "visual"
          ]
        }
      },
      "_key": "!actors.items!redMantisAssn001.3F9wdRX9orioME1X"
    },
    {
      "_id": "H6YMby3cP1KHHPxt",
      "img": "systems/pf2e/icons/actions/OneAction.webp",
      "name": "Red Shroud",
      "sort": 0,
      "type": "action",
      "system": {
        "actionType": {
          "value": "action"
        },
        "actions": {
          "value": 1
        },
        "category": "defensive",
        "description": {
          "value": "<p><strong>Frequency</strong> twice per day. A veil of red mist (unaffected by wind) wreathes the assassin for 3 rounds: +1 circumstance bonus to AC and fast healing 2. If she dies while shrouded, she may disintegrate into red mist, leaving only her gear — denying enemies her remains.</p>"
        },
        "publication": {
          "title": "Pathfinder: Curse of the Crimson Throne (PF2e conversion, private)",
