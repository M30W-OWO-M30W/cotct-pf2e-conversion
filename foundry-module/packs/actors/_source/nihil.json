    {
      "_id": "PZte31vPN2GZLAMJ",
      "img": "systems/pf2e/icons/actions/Passive.webp",
      "name": "SPIRIT ANCHOR",
      "sort": 0,
      "type": "action",
      "system": {
        "actionType": {
