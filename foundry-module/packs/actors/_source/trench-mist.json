    {
      "type": "action",
      "img": "systems/pf2e/icons/actions/Passive.webp",
      "name": "Create Juju Zombie",
      "system": {
        "description": {
          "value": "<p>A trench mist can animate any corporeal creature that is slain while engulfed within the mist's form. The victim rises as a juju zombie in [[/br 1d4 #rounds]]{1d4 rounds}, and is under the control of the trench mist that created it. A juju zombie becomes free-willed if it is separated from its parent trench mist.</p>"
        },
