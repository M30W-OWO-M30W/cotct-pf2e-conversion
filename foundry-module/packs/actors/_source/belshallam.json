    {
      "_id": "Bw14WI5Q6qu7scz8",
      "img": "systems/pf2e/icons/actions/Passive.webp",
      "name": "SPIRIT ANCHOR",
      "sort": 0,
      "type": "action",
      "system": {
        "actionType": {
