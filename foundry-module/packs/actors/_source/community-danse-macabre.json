    {
      "type": "action",
      "img": "systems/pf2e/icons/actions/Passive.webp",
      "name": "Drain Life",
      "system": {
        "description": {
          "value": "<p>When the danse macabre damages a living creature with its ghostly scythe Strike, it gains 5 temporary Hit Points and the creature must succeed at a @Check[type:fortitude|dc:33] save or become @Compendium[pf2e.conditionitems.Drained]{Drained 1}. Further damage dealt by the danse macabre increases the drained condition value by 1 on a failed save, to a maximum of @Compendium[pf2e.conditionitems.Drained]{Drained 4}.</p>"
        },
