    {
      "type": "action",
      "img": "systems/pf2e/icons/actions/Passive.webp",
      "name": "Dance of Death",
      "system": {
        "description": {
          "value": "<p>@Template[type:emanation|distance:40] @Compendium[pf2e.bestiary-ability-glossary-srd.Aura]{Aura}</p>\n<p>A danse macabre is surrounded by an endless gala of dancing spectral figures. Any living creature that enters or ends its turn in the aura must attempt a @Check[type:will|dc:34] save.</p>\n<hr>\n<p><strong>Critical Success</strong> The creature is unaffected.</p>\n<p><strong>Success</strong> The creature is @Compendium[pf2e.conditionitems.Flat-Footed]{Flat-Footed} and cannot use reactions until the end of its next turn. Additionally, it must spend its first action after this save dancing. Dancing is a move action that allows the creature to Stride up to half its Speed.</p>\n<p><strong>Failure</strong> As success, except the creature must spend its next 2 actions dancing.</p>\n<p><strong>Critical Failure</strong> As failure, except the creature must spend its next 3 actions dancing.</p>"
        },
        "source": {
          "value": ""
        },
        "traits": {
          "value": [
            "auditory",
            "aura",
