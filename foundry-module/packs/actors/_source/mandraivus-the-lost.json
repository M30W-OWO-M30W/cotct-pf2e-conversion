    {
      "type": "action",
      "img": "systems/pf2e/icons/actions/Passive.webp",
      "name": "Wraith Spawn",
      "system": {
        "description": {
          "value": "<p>A living humanoid slain by Mandraivus the Lost's spectral hand Strike rises as a wraith spawn after [[/br 1d4 #rounds]]{1d4 rounds}. This wraith spawn is under the command of Mandraivus the Lost. It doesn't have drain life or wraith spawn. If Mandraivus the Lost is slain, the wraith spawn becomes a full-fledged, autonomous wraith; it regains its free will and gains drain life and wraith spawn.</p>"
