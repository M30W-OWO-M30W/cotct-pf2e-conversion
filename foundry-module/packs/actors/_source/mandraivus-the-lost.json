    {
      "type": "action",
      "img": "systems/pf2e/icons/actions/Passive.webp",
      "name": "Drain Life",
      "system": {
        "description": {
          "value": "<p>When Mandraivus the Lost damages a living creature with its spectral hand Strike, it gains 10 temporary Hit Points and the target must succeed at a @Check[type:fortitude|dc:34] save or become @Compendium[pf2e.conditionitems.Drained]{Drained 1}. Further damage dealt by Mandraivus the Lost increases the drained condition value by 1 on a failed save, to a maximum of @Compendium[pf2e.conditionitems.Drained]{Drained 4}.</p>"
