    },
    {
      "_id": "GOxFk2E8n3etWld8",
      "img": "systems/pf2e/icons/actions/Passive.webp",
      "name": "Bound to the Labyrinth",
      "sort": 0,
      "type": "action",
      "system": {
        "actionType": {
          "value": "passive"
        },
        "actions": {
          "value": null
        },
        "category": "defensive",
        "description": {
          "value": "<p>An old <em>binding</em> (cast by Bahor's slain predecessor, with no release clause) chains her to the dungeon — she cannot pass E2. The same geas compels her to <strong>attack any betrayer of Bahor</strong> she discovers… including Vimanda.</p>"
        },
        "publication": {
