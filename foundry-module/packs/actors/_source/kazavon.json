    {
      "_id": "J2NeT68ap4maPJ1I",
      "img": "systems/pf2e/icons/actions/OneAction.webp",
      "name": "Human Form",
      "sort": 0,
      "type": "action",
      "system": {
        "actionType": {
          "value": "action"
        },
        "actions": {
          "value": 1
        },
        "category": "offensive",
        "description": {
          "value": "<p>Zon-Kuthon's gift: a fixed human shape — the pale warlord (AC 47; <em>+3 greater striking unholy spiked chain</em> +44, @Damage[3d8+22[slashing]] plus @Damage[1d6[bleed]]). <strong>Death Transformation:</strong> at 0 HP in human form he erupts back into the dragon at full HP, @UUID[Compendium.pf2e.conditionitems.Item.xYTAsEpcJE1Ccni3]{Slowed 1} for 2d4 rounds, his armor destroyed. In human form he fights to the death — because death is a costume change.</p>"
        },
        "publication": {
          "title": "Pathfinder: Curse of the Crimson Throne (PF2e conversion, private)",
          "authors": "",
          "license": "OGL",
          "remaster": true
        },
