    {
      "type": "action",
      "img": "systems/pf2e/icons/actions/TwoActions.webp",
      "name": "Horrific Pantomime",
      "system": {
        "description": {
          "value": "<p>Any creature within 60 feet who can see Pegg or Loute's horrific pantomime must attempt a @Check[type:will|dc:25] save.</p>\n<hr>\n<p><strong>Critical Success</strong> The creature is unaffected and immune to Horrific Pantomime for 24 hours.</p>\n<p><strong>Success</strong> The creature is @Compendium[pf2e.conditionitems.Stupefied]{Stupefied 1}.</p>\n<p><strong>Failure</strong> The creature is @Compendium[pf2e.conditionitems.Stupefied]{Stupefied 2}.</p>\n<p><strong>Critical Failure</strong> The creature is @Compendium[pf2e.conditionitems.Stupefied]{Stupefied 2} and @UUID[Compendium.pf2e.conditionitems.dfCMdR4wnpbYNTix]{Stunned} for 1 round as they become mesmerized by the pantomime.</p>"
        },
