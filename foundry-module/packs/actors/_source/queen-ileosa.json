    {
      "_id": "WsPPx0iILuPdstfo",
      "img": "systems/pf2e/icons/actions/FreeAction.webp",
      "name": "Unleash the Stored Queens",
      "sort": 0,
      "type": "action",
      "system": {
        "actionType": {
          "value": "free"
        },
        "actions": {
          "value": null
        },
        "category": "offensive",
        "description": {
          "value": "<p><strong>Trigger</strong> She notices intruders at the Pool.</p><hr /><p><strong>Effect</strong> The Pool shudders, ripples into the Korvosa skyline, crumbles — then her shrieking face surfaces (no speech; only fury) and she releases her <strong>six stored @UUID[Compendium.cotct-pf2e-conversion.cotct-actors.Actor.falseIleosa00001]{simulacrums}</strong>. Her surviving @UUID[Compendium.cotct-pf2e-conversion.cotct-actors.Actor.ileosasFury00001]{Furies} teleport in; @UUID[Compendium.cotct-pf2e-conversion.cotct-actors.Actor.ithierGylou00001]{Ithier} climbs from below; the Pool spins up a @UUID[Compendium.cotct-pf2e-conversion.cotct-actors.Actor.taniniverKaz0001]{taniniver} (5 charges).</p>"
        },
