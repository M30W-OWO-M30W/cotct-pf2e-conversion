    {
      "img": "systems/pf2e/icons/actions/Passive.webp",
      "name": "Sneak Attack",
      "system": {
        "description": {
          "value": "<p>Hookshanks deals an extra [[/r 1d6]] precision damage to flat-footed creatures.</p>\n<hr>\n<p>@Localize[PF2E.NPC.Abilities.Glossary.SneakAttack]</p>"
        },
        "source": {
          "value": "Pathfinder Bestiary"
        },
        "traits": {
          "value": [],
          "rarity": "common",
          "custom": ""
        },
        "rules": [
          {
            "category": "precision",
            "diceNumber": 1,
            "dieSize": "d6",
            "key": "DamageDice",
            "predicate": [
              "target:condition:flat-footed",
              {
                "or": [
                  "item:trait:agile",
                  "item:trait:finesse",
                  {
                    "and": [
                      "item:ranged",
                      {
                        "not": "item:thrown-melee"
                      }
                    ]
                  }
                ]
              }
            ],
            "selector": "strike-damage"
          },
          {
            "domain": "all",
