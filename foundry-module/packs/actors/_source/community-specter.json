      "sort": 700000,
      "system": {
        "description": {
          "value": "<p>A specter caught in sunlight is @UUID[Compendium.pf2e.conditionitems.i3OJZU2nk64Df3xm]{Clumsy 2} and @UUID[Compendium.pf2e.conditionitems.xYTAsEpcJE1Ccni3]{Slowed 2} for as long as it remains in the sunlight.</p>"
