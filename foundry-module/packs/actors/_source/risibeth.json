    {
      "type": "action",
      "img": "systems/pf2e/icons/actions/ThreeActions.webp",
      "name": "Living Form",
      "system": {
        "description": {
          "value": "<p><strong>Requirements</strong> The sayona has successfully used Drink Blood or Absorb Blood in the past hour.</p>\n<hr>\n<p><strong>Effect</strong> A sayona can transform into a young, beautiful form resembling the body it had in life, with the effects of humanoid form for 24 hours. It loses its fangs and claw Strikes but gains a +2 circumstance bonus to Deception checks to Impersonate in this form. Exposure to holy water or positive energy in this form reduces the duration of this transformation by [[/br 1d4 #hours]]{1d4 hours}.</p>"
        },
