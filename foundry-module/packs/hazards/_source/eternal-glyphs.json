  "items": [
    {
      "type": "action",
      "img": "systems/pf2e/icons/actions/Reaction.webp",
      "name": "Suggested Reading",
      "system": {
        "description": {
          "value": "<p><strong>Trigger</strong> A creature begins reading the scripture.</p>\n<p><strong>Effect</strong> A powerful suggestion spell grips the reader, who must attempt a @Check[type:will|dc:25] save to avoid becoming entranced by the scripture.</p>\n<p><strong>Success</strong> The reader is unaffected by the suggestion.</p>\n<p><strong>Failure</strong> The reader becomes entranced by the suggestion for 1 hour and may take no actions other than reading the scripture. After which, the reader may attempt another Will save with a -1 penalty. This penalty is in addition to any previous penalties applied by the eternal glyphs.</p>\n<p><strong>Critical Failure</strong> The reader becomes entranced by the suggestion for 1 day and may take no actions other than reading the scripture. After which, the reader may attempt another Will save with a -2 penalty. This penalty is in addition to any previous penalties applied by the eternal glyphs.</p>"
        },
