      "stealth": {
        "details": "<p>It announces itself: a wall of black ash on the horizon. @Check[type:survival|dc:30] (expert) to predict its path an hour ahead.</p>",
        "value": 20
      }
    },
    "creatureType": "",
    "details": {
      "description": "<p>The Cinderlands' burning dust storms. The <strong>edge</strong> (outermost 100 feet) is a severe windstorm: difficult terrain, everything is concealed beyond 30 feet, ranged attacks take −4. The <strong>heart</strong> is on fire.</p>",
      "disable": "<p>@Check[type:survival|dc:30] (expert) to lead the group out of the heart to the storm's edge (one check per 10 minutes); reaching real shelter — a gorge, a lotra grove, a tent buried in ash — ends exposure.</p>",
      "isComplex": true,
      "level": {
        "value": 11
      },
      "publication": {
        "title": "Pathfinder: Curse of the Crimson Throne (PF2e conversion, private)",
        "authors": "",
        "license": "OGL",
        "remaster": true
      },
      "reset": "<p>A storm runs 1d4 hours, then collapses into drifting ash.</p>",
      "routine": "<p>(1 action) The storm advances 60 feet in a direction of the wind's choosing; everything in the heart takes the Burning Heart damage.</p>"
