    {
      "type": "action",
      "img": "systems/pf2e/icons/actions/TwoActions.webp",
      "name": "Maiden's Scream",
      "system": {
        "description": {
          "value": "<p>A deafening shriek emits from each iron maiden along the walls. Any creature adjacent to an iron maiden must attempt a @Check[type:fortitude|dc:24] save.</p>\n<hr>\n<p><strong>Critical Success</strong> The creature is @Compendium[pf2e.conditionitems.Deafened]{Deafened} for 1 round.</p>\n<p><strong>Success</strong> The creature is @Compendium[pf2e.conditionitems.Stunned]{Stunned 1} and @Compendium[pf2e.conditionitems.Deafened]{Deafened} for 1 round.</p>\n<p><strong>Failure</strong> The creature is @Compendium[pf2e.conditionitems.Stunned]{Stunned 2} and @Compendium[pf2e.conditionitems.Deafened]{Deafened} for 1 minute.</p>\n<p><strong>Critical Failure</strong> The creature is @Compendium[pf2e.conditionitems.Stunned]{Stunned} for 1 round and @Compendium[pf2e.conditionitems.Deafened]{Deafened} for 1 minute.</p>"
        },
