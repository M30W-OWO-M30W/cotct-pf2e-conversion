    {
      "type": "action",
      "img": "systems/pf2e/icons/actions/Reaction.webp",
      "name": "Dutiful Strike",
      "system": {
        "description": {
          "value": "<p><strong>Trigger</strong> A foe within 15 feet of Sial hits him with a Strike and deals damage.</p>\n<p><strong>Requirements</strong> Asyra is adjacent to Sial.</p>\n<p><strong>Effect</strong> Asyra instinctively flashes with ectoplasmic energy, allowing her to make a melee attack against a foe who dares to harm Sial. Asyra makes a phantom fist Strike against the triggering foe, even if that foe isn't within Asyra's reach.</p>"
        },
