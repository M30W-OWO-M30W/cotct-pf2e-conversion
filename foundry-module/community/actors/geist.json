    {
      "type": "action",
      "img": "systems/pf2e/icons/actions/Passive.webp",
      "name": "Drain Life",
      "system": {
        "description": {
          "value": "<p>When the geist damages a living creature with its spectral jaws Strike, the geist gains 10 temporary Hit Points and the target must succeed at a @Check[type:fortitude|dc:28] save or become @Compendium[pf2e.conditionitems.Drained]{Drained 1}. Further damage dealt by the geist increases the drained condition value by 1 on a failed save, to a maximum of @Compendium[pf2e.conditionitems.Drained]{Drained 4}.</p>"
        },
