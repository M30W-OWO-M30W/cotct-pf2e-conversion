    {
      "type": "action",
      "img": "systems/pf2e/icons/actions/OneAction.webp",
      "name": "Punishing Momentum",
      "system": {
        "description": {
          "value": "<p><strong>Requirements</strong> The animated taxidermic wyvern @Compendium[pf2e.conditionitems.Grabbed]{Grabbed} a creature this turn using Powerful Dive.</p>\n<p><strong>Effect</strong> The animated taxidermic wyvern can Fly at half Speed while holding the creature in its claws, carrying that creature along with it and dropping it at the end of its movement.<br>Alternatively, the animated taxidermic wyvern can Strike the creature with its stinger with a +2 circumstance bonus.</p>"
        },
        "source": {
