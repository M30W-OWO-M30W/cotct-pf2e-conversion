    {
      "type": "action",
      "img": "systems/pf2e/icons/actions/Passive.webp",
      "name": "Construct Armor",
      "system": {
        "description": {
          "value": "<p>Like normal objects, an animated taxidermic wyvern has Hardness. This Hardness reduces any damage it takes by an amount equal to the Hardness. Once an animated taxidermic wyvern is reduced to less than half its Hit Points, or immediately upon being damaged by a critical hit, its construct armor breaks and its Armor Class is reduced to 29.</p>"
