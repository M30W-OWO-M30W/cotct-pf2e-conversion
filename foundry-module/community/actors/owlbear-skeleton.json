    {
      "type": "action",
      "img": "systems/pf2e/icons/actions/OneAction.webp",
      "name": "Gnaw",
      "system": {
        "description": {
          "value": "<p><strong>Requirements</strong> The owlbear skeleton has a creature @Compendium[pf2e.conditionitems.Grabbed]{Grabbed} with its talons.</p>\n<p><strong>Effect</strong> The owlbear attempts to disembowel the creature with a beak Strike. If the Strike hits, the target must attempt a @Check[type:will|dc:15] save.</p>\n<hr>\n<p><strong>Critical Success</strong> The target is unaffected.</p>\n<p><strong>Success</strong> The target is @Compendium[pf2e.conditionitems.Sickened]{Sickened 1}.</p>\n<p><strong>Failure</strong> The target is @Compendium[pf2e.conditionitems.Sickened]{Sickened 1} and @Compendium[pf2e.conditionitems.Slowed]{Slowed 1} as long as it remains sickened.</p>"
        },
