    {
      "type": "action",
      "img": "systems/pf2e/icons/actions/TwoActions.webp",
      "name": "Brutal Blow",
      "system": {
        "description": {
          "value": "<p>Cabbagehead makes fist Strike. If it hits, in addition to dealing damage, the creature must attempt a @Check[type:fortitude|dc:20] saving throw, with the following effects.</p>\n<hr>\n<p><strong>Critical Success</strong> The creature is unaffected and Cabbagehead is @Compendium[pf2e.conditionitems.Flat-Footed]{Flat-Footed} until the start of his next turn.</p>\n<p><strong>Success</strong> The creature is unaffected.</p>\n<p><strong>Failure</strong> The creature is pushed 10 feet.</p>\n<p><strong>Critical Failure</strong> The target is pushed 10 feet and knocked @Compendium[pf2e.conditionitems.Prone]{Prone}.</p>"
        },
