      "stealth": {
        "value": 25,
        "details": "<p>(trained) to see the blood on the scroll start to glisten and soak through the parchment.</p>\n<hr>\n<p><strong>Destruction</strong> Unlike the other haunts in Scarwall, lifting the castle's curse does not destroy this haunt. To do so, Kleestad himself, in his new incarnation as a pharmakos, must be slain (see Area <strong>H4</strong>).</p>"
      },
      "emitsSound": "encounter"
    },
    "details": {
      "isComplex": false,
      "level": {
        "value": 13
      },
      "disable": "<p>@Check[type:religion|dc:33] (master) or dispel magic (7th level; counteract DC 31) to suppress the scroll's desire to possess for 1 minute.</p>",
      "description": "<p>A bleeding scroll that forces its bearer to relive the final, horrid moments of Kleestad's life.</p>",
