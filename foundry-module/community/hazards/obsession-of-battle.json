    "details": {
      "isComplex": true,
      "level": {
        "value": 12
      },
      "disable": "<p>@Check[type:religion|dc:32] (master) or dispel magic (6th level; counteract DC 30) to suppress the ghosts for 1 minute.</p>",
      "description": "<p>A dusty room in which ghostly images of castle guards manifest and possess creatures to succumb to violence and lash out at any person near them, friend or foe.</p>\n<hr>\n<p><strong>Destruction </strong>If the curse upon Scarwall is lifted or the geists in C8 are destroyed, this haunt fades away.</p>",
      "reset": "<p>The haunt grows quiet and resets 1 minute after there are no living creatures in area C7. If the geists in area C8 are still alive and control the haunt, this time is reduced to 5 rounds.</p>",
      "routine": "<p><span class=\"pf2-icon\">T</span> As All Must Die, but the haunt randomly chooses a new living target in area C7. This new target cannot be a previously possessed creature.</p>"
    },
